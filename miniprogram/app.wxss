/* =============================================
   Canteen 设计系统 — Design Tokens
   ============================================= */
page {
  /* 颜色 */
  --color-bg: #f5f7f8;
  --color-surface: #ffffff;
  --color-surface-alt: #f9fafb;

  --color-primary: #0f5f9f;
  --color-primary-dark: #0b2a4a;
  --color-primary-soft: #dbeafe;
  --color-primary-line: #93c5fd;

  --color-accent: #ed8936;
  --color-accent-soft: #fef3c7;

  --color-text: #1f2937;
  --color-text-secondary: #4b5563;
  --color-text-muted: #9ca3af;

  --color-border: #e5e7eb;
  --color-divider: #f1f3f5;

  --color-success: #10b981;
  --color-success-soft: #d1fae5;
  --color-warning: #f59e0b;
  --color-warning-soft: #fef3c7;
  --color-danger: #ef4444;
  --color-danger-soft: #fee2e2;
  --color-info: #3b82f6;
  --color-info-soft: #dbeafe;

  /* 圆角 */
  --radius-sm: 10rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-xl: 28rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
  --shadow-md: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  --shadow-lg: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);

  /* 基础 */
  min-height: 100%;
  background: var(--color-bg);
  color: var(--color-text);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Source Han Sans SC", "Noto Sans CJK SC", sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* =============================================
   布局
   ============================================= */
.container {
  padding: 24rpx;
}

.inline {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.space-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

/* =============================================
   卡片
   ============================================= */
.card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

/* =============================================
   标题与文字
   ============================================= */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}

.muted {
  color: var(--color-text-muted);
  font-size: 24rpx;
}

/* =============================================
   按钮
   ============================================= */
.primary-btn {
  background: var(--color-primary);
  color: #ffffff;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(15, 95, 159, 0.18);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.primary-btn::after {
  border: none;
}

.primary-btn[disabled],
button.primary-btn[disabled][type] {
  background: #cbd5d4;
  color: #ffffff;
  box-shadow: none;
  opacity: 1;
  font-weight: 600;
}

.warn-btn {
  background: var(--color-danger);
  color: #ffffff;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.18);
}

.warn-btn::after {
  border: none;
}

.warn-btn[disabled] {
  background: #cbd5d4;
  color: #ffffff;
  box-shadow: none;
  opacity: 1;
}

.subtle-btn {
  background: var(--color-surface);
  color: var(--color-primary);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid var(--color-primary-line);
}

.subtle-btn::after {
  border: none;
}

.subtle-btn[disabled] {
  background: var(--color-divider);
  color: var(--color-text-muted);
  border-color: var(--color-border);
}

.ghost-btn {
  background: transparent;
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 24rpx;
}

.ghost-btn::after {
  border: none;
}

/* =============================================
   输入框
   ============================================= */
.input {
  width: 100%;
  box-sizing: border-box;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-md);
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  margin-bottom: 16rpx;
  color: var(--color-text);
  font-size: 28rpx;
}

.input:focus {
  border-color: var(--color-primary);
}

/* =============================================
   状态标签
   ============================================= */
.status-tag {
  display: inline-block;
  font-size: 22rpx;
  line-height: 1;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.status-booked {
  color: var(--color-info);
  background: var(--color-info-soft);
}

.status-verified {
  color: var(--color-success);
  background: var(--color-success-soft);
}

.status-cancelled {
  color: var(--color-danger);
  background: var(--color-danger-soft);
}

.status-unknown {
  color: var(--color-text-secondary);
  background: var(--color-divider);
}

/* =============================================
   空状态
   ============================================= */
.empty-text {
  text-align: center;
  color: var(--color-text-muted);
  padding: 60rpx 0;
  font-size: 26rpx;
}

/* =============================================
   选择器（picker）
   ============================================= */
.picker-value {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 18rpx 22rpx;
  color: var(--color-text);
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

/* =============================================
   工具类
   ============================================= */
.text-primary {
  color: var(--color-primary);
}

.text-accent {
  color: var(--color-accent);
}

.text-secondary {
  color: var(--color-text-secondary);
}

.divider {
  height: 1rpx;
  background: var(--color-divider);
  margin: 16rpx 0;
}
