   我的订单
   ============================================= */
.picker-row {
  margin-bottom: 14rpx;
}

.picker-value {
  color: var(--color-primary-dark);
  font-weight: 700;
  background: var(--color-primary-soft);
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.order-card {
  padding: 22rpx 24rpx;
  position: relative;
}

.order-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 0 4rpx 4rpx 0;
  background: var(--color-primary);
}

.order-no {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 6rpx;
}

.items-wrap {
  margin: 14rpx 0;
}

.item-pill {
  display: inline-block;
  margin: 0 10rpx 10rpx 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--color-primary-dark);
  background: var(--color-primary-soft);
  font-weight: 500;
}
