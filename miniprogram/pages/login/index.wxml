<view class="container">
  <view class="card brand-card">
    <view class="brand-logo">食</view>
    <view class="brand-title">公安食堂订餐</view>
    <view class="muted">健康饮食 · 准时供应</view>
  </view>

  <view class="card">
    <view class="mode-switch">
      <view
        class="mode-item {{mode === 'login' ? 'mode-active' : ''}}"
        data-mode="login"
        bindtap="switchMode"
      >
        账号登录
      </view>
      <view
        class="mode-item {{mode === 'bind' ? 'mode-active' : ''}}"
        data-mode="bind"
        bindtap="switchMode"
      >
        首次绑定
      </view>
    </view>

    <block wx:if="{{mode === 'login'}}">
      <input
        class="input"
        placeholder="警号或手机号"
        value="{{loginAccount}}"
        data-field="loginAccount"
        bindinput="onInput"
      />
      <input
        class="input"
        placeholder="密码"
        password="true"
        value="{{loginPassword}}"
        data-field="loginPassword"
        bindinput="onInput"
      />
      <button class="primary-btn" loading="{{loading}}" bindtap="submitLogin">登录</button>
    </block>

    <block wx:else>
      <input
        class="input"
        placeholder="警号（可选）"
        value="{{bindPoliceNo}}"
        data-field="bindPoliceNo"
        bindinput="onInput"
      />
      <input
        class="input"
        placeholder="手机号（可选）"
        value="{{bindMobile}}"
        data-field="bindMobile"
        bindinput="onInput"
      />
      <input
        class="input"
        placeholder="姓名"
        value="{{bindRealName}}"
        data-field="bindRealName"
        bindinput="onInput"
      />
      <view class="muted hint-text">警号与手机号至少填写其一。首次绑定后默认密码为 123456，请及时修改。</view>
      <button class="primary-btn" loading="{{loading}}" bindtap="submitBind">绑定并登录</button>
    </block>
  </view>
</view>
