/* =============================================
   登录页
   ============================================= */
.brand-card {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #0f5f9f 0%, #0b2a4a 100%);
  color: #ffffff;
  border: 0;
  padding: 48rpx 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 95, 159, 0.18);
  text-align: center;
}

.brand-logo {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
}

.brand-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.brand-card .muted {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.mode-switch {
  display: flex;
  background: var(--color-divider);
  border-radius: 999rpx;
  padding: 6rpx;
  margin-bottom: 28rpx;
}

.mode-item {
  flex: 1;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.mode-active {
  background: var(--color-primary);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(15, 95, 159, 0.22);
}

.hint-text {
  font-size: 24rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
  padding: 16rpx 18rpx;
  background: var(--color-warning-soft);
  color: #92400e;
  border-radius: var(--radius-md);
}

.brand-card + .card {
  padding: 36rpx 28rpx;
}

.brand-card + .card .primary-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx;
  margin-top: 12rpx;
}
