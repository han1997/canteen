.half-btn {
  flex: 1;
  margin-right: 10rpx;
}

.half-btn:last-child {
  margin-right: 0;
}

.create-toggle {
  margin-top: 14rpx;
}

.picker-value {
  background: linear-gradient(135deg, #eef4fd 0%, #e0ebf9 100%);
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  color: #0b2a4a;
  margin-bottom: 16rpx;
}

.user-card {
  padding-top: 18rpx;
  border-left: 8rpx solid #0b2a4a;
}

.user-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0b2a4a;
  margin-bottom: 6rpx;
}

.action-row {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 10rpx;
  align-items: center;
}

.picker-role {
  min-width: 0;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #edf4fd;
  color: #0b2a4a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.action-row button {
  margin: 0;
  white-space: nowrap;
}

.edit-form {
  padding: 4rpx 0;
}

.hint-small {
  font-size: 22rpx;
  margin-top: -8rpx;
  margin-bottom: 8rpx;
}
