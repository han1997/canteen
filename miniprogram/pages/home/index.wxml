<view class="container">
  <view class="card hero-home">
    <view class="space-between home-head">
      <view>
        <view class="section-title">订餐主页</view>
        <view class="muted">{{profile.real_name}}（{{profile.police_no || profile.mobile}}）</view>
      </view>
      <view class="inline top-actions">
        <view class="icon-action" bindtap="goProfile">
          <view class="icon-dot">我</view>
          <view class="icon-text">个人</view>
        </view>
        <view wx:if="{{canManage}}" class="icon-action" bindtap="goManage">
          <view class="icon-dot">管</view>
          <view class="icon-text">管理</view>
        </view>
        <view class="icon-action" bindtap="logout">
          <view class="icon-dot">退</view>
          <view class="icon-text">退出登录</view>
        </view>
      </view>
    </view>
    <view class="space-between filter-row">
      <text class="muted">订餐日期</text>
      <picker mode="date" value="{{mealDate}}" bindchange="onDateChange">
        <view class="date-value">{{mealDate}}</view>
      </picker>
    </view>

    <!-- 顶部餐别 tab -->
    <view class="meal-tabs">
      <view
        wx:for="{{mealTabs}}"
        wx:key="value"
        wx:for-index="tabIndex"
        class="meal-tab {{activeMealIndex === tabIndex ? 'meal-tab-active' : ''}}"
        data-index="{{tabIndex}}"
        bindtap="onMealTabChange"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card">
    <view class="empty-text">加载中...</view>
  </view>

  <view wx:elif="{{!activeSlot}}" class="card">
    <view class="empty-text">该日期暂无{{mealTabs[activeMealIndex].label}}时段</view>
  </view>

  <block wx:else>
    <!-- 订单状态栏 -->
    <view class="card slot-status-card">
      <view class="space-between">
        <view class="slot-title">{{activeSlot.mealTypeLabel}}</view>
        <text class="{{activeSlot.canBook ? 'status-tag status-verified' : 'status-tag status-cancelled'}}">
          {{activeSlot.slotStatus}}
        </text>
      </view>
      <view wx:if="{{activeSlot.bookingDeadline}}" class="muted">截止时间：{{activeSlot.deadlineText}}</view>
      <view wx:if="{{activeSlot.selectedOrder}}" class="order-tip">
        <text>当前订单：{{activeSlot.selectedOrder.orderNo}}</text>
        <text class="muted">（{{activeSlot.selectedOrder.status}}）</text>
      </view>
      <view wx:if="{{activeSlot.isBreakfast}}" class="breakfast-tip">早餐为单点，可多种叠加下单</view>
    </view>

    <!-- 左侧分类 nav + 右侧菜品列表 -->
    <view class="meal-body">
      <!-- 左侧分类导航：早餐不显示 -->
      <view wx:if="{{!activeSlot.isBreakfast}}" class="category-nav">
        <view
          wx:for="{{categoryNavs}}"
          wx:key="value"
          wx:for-index="catIndex"
          class="category-item {{activeCategoryIndex === catIndex ? 'category-item-active' : ''}}"
          data-index="{{catIndex}}"
          bindtap="onCategoryChange"
        >
          {{item.label}}
        </view>
      </view>

      <!-- 右侧菜品列表 -->
      <view class="meal-list {{activeSlot.isBreakfast ? 'meal-list-full' : ''}}">
        <view wx:if="{{!activePackages.length}}" class="empty-text">
          {{activeSlot.isBreakfast ? '暂无菜品' : '该分类下暂无菜品'}}
        </view>
        <block wx:for="{{activePackages}}" wx:key="id" wx:for-item="pkg" wx:for-index="pkgIndex">
          <view class="package-card {{pkg.qty > 0 ? 'package-selected' : ''}}">
            <image
              class="package-image"
              src="{{pkg.imageUrl}}"
              mode="aspectFill"
              data-package-index="{{pkgIndex}}"
              binderror="onPackageImageError"
              lazy-load="true"
            />
            <view class="pkg-main">
              <view class="pkg-title">{{pkg.packageName}}</view>
              <view class="price-line">¥{{pkg.price || 0}} / {{pkg.unit}}</view>
              <view class="qty-row">
                <view
                  class="qty-btn {{!activeSlot.canBook ? 'qty-disabled' : ''}}"
                  data-package-id="{{pkg.id}}"
                  data-delta="-1"
                  bindtap="adjustQty"
                >
                  -
                </view>
                <view class="qty-value">{{pkg.qty}}</view>
                <view
                  class="qty-btn {{!activeSlot.canBook ? 'qty-disabled' : ''}}"
                  data-package-id="{{pkg.id}}"
                  data-delta="1"
                  bindtap="adjustQty"
                >
                  +
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-bar">
      <button
        class="primary-btn"
        loading="{{placing && placingSlotId === activeSlot.id}}"
        disabled="{{!activeSlot.canBook || placing}}"
        bindtap="submitSlotOrder"
      >
        提交本时段订单
      </button>
    </view>
  </block>
</view>
