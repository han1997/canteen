.top-actions {
  flex-wrap: nowrap;
  justify-content: flex-end;
  gap: 10rpx;
}

.icon-action {
  width: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0b2a4a 0%, #1d4d82 100%);
  color: #ffffff;
  text-align: center;
  line-height: 52rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.icon-text {
  margin-top: 6rpx;
  color: #0b2a4a;
  font-size: 20rpx;
}

.filter-row {
  margin-top: 12rpx;
}

.date-value {
  color: #0b2a4a;
  font-weight: 700;
  background: #edf4fd;
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
}

.slot-card {
  padding-top: 18rpx;
  border-left: 8rpx solid #0b2a4a;
}

.order-tip {
  margin: 14rpx 0 6rpx;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #edf6ff;
  font-size: 24rpx;
  color: #0b2a4a;
}

.breakfast-tip {
  margin: 10rpx 0;
  color: #6c3f0d;
  font-size: 24rpx;
  background: #fff2de;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
}

.package-card {
  border: 1rpx solid #d7e3f3;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  background: #fbfdff;
}

.package-selected {
  border-color: #0b2a4a;
  background: linear-gradient(145deg, #edf4fd 0%, #e4eefb 100%);
}

.pkg-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a2f4a;
}

.pkg-cat {
  color: #0b2a4a;
  font-size: 24rpx;
  background: #deebfb;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.price-line {
  margin-top: 10rpx;
  color: #0b2a4a;
  font-size: 25rpx;
  font-weight: 600;
}

.nutrition-line {
  margin: 8rpx 0 14rpx;
  font-size: 24rpx;
}

.qty-row {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 58rpx;
  height: 58rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #0b2a4a 0%, #1d4d82 100%);
  color: #ffffff;
  text-align: center;
  line-height: 58rpx;
  font-size: 34rpx;
}

.qty-disabled {
  background: #b7c2d0;
}

.qty-value {
  width: 104rpx;
  text-align: center;
  color: #0b2a4a;
  font-size: 30rpx;
  font-weight: 700;
}
