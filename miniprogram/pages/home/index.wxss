/* =============================================
   订餐主页
   ============================================= */

/* 顶部 hero 卡片 */
.hero-home {
  background: linear-gradient(135deg, #0f5f9f 0%, #0b2a4a 100%);
  border: none;
  color: #ffffff;
}

.hero-home .section-title,
.hero-home .muted {
  color: #ffffff;
}

.hero-home .muted {
  opacity: 0.85;
}

.home-head {
  align-items: flex-start;
}

.top-actions {
  flex-wrap: nowrap;
  justify-content: flex-end;
  gap: 8rpx;
}

.icon-action {
  width: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.icon-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  text-align: center;
  line-height: 56rpx;
  font-size: 26rpx;
  font-weight: 700;
  backdrop-filter: blur(8rpx);
}

.icon-text {
  color: rgba(255, 255, 255, 0.85);
  font-size: 20rpx;
}

/* 日期选择 */
.filter-row {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.filter-row .muted {
  color: rgba(255, 255, 255, 0.8);
}

.date-value {
  color: #0b2a4a;
  font-weight: 700;
  background: #ffffff;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

/* 顶部餐别 tab */
.meal-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 20rpx;
  padding: 6rpx;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 999rpx;
}

.meal-tab {
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  border-radius: 999rpx;
  transition: background 0.2s ease;
}

.meal-tab-active {
  background: #ffffff;
  color: #0b2a4a;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 状态卡片 */
.slot-status-card {
  padding: 24rpx 28rpx;
}

.slot-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.order-tip {
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-soft);
  font-size: 26rpx;
  color: var(--color-primary-dark);
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.order-tip .muted {
  color: var(--color-primary);
}

.breakfast-tip {
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  color: #92400e;
  font-size: 26rpx;
  background: var(--color-warning-soft);
  border-radius: var(--radius-md);
}

/* 左侧 nav + 右侧 list */
.meal-body {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.category-nav {
  width: 168rpx;
  flex-shrink: 0;
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  box-shadow: var(--shadow-sm);
  align-self: flex-start;
}

.category-item {
  padding: 22rpx 14rpx;
  font-size: 26rpx;
  text-align: center;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all 0.18s ease;
}

.category-item-active {
  background: var(--color-primary);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(15, 95, 159, 0.22);
}

/* 右侧菜品列表 */
.meal-list {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.package-card {
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 14rpx;
  background: var(--color-surface);
  display: flex;
  gap: 14rpx;
  align-items: stretch;
  box-shadow: var(--shadow-sm);
  transition: border-color 0.18s ease, background 0.18s ease;
}

.package-selected {
  border-color: var(--color-primary);
  background: var(--color-primary-soft);
}

.package-image {
  width: 144rpx;
  height: 144rpx;
  border-radius: var(--radius-md);
  background: var(--color-divider);
  flex-shrink: 0;
}

.pkg-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.pkg-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.price-line {
  color: var(--color-primary-dark);
  font-size: 26rpx;
  font-weight: 600;
}

.qty-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 8rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary);
  color: #ffffff;
  text-align: center;
  line-height: 56rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(15, 95, 159, 0.16);
}

.qty-disabled {
  background: var(--color-text-muted);
  box-shadow: none;
}

.qty-value {
  width: 76rpx;
  text-align: center;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 700;
}

/* 底部提交按钮 */
.submit-bar {
  margin-top: 8rpx;
  padding: 0 4rpx;
}

.submit-bar .primary-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx;
}
