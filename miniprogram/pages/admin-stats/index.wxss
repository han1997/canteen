.grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.grid-item {
  width: 33.33%;
  text-align: center;
  margin-bottom: 16rpx;
}

.metric-value {
  color: #0b2a4a;
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 4rpx;
}

.picker-row {
  margin-bottom: 14rpx;
}

.picker-value {
  background: linear-gradient(135deg, #eef4fd 0%, #e0ebf9 100%);
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  color: #0b2a4a;
  margin-bottom: 16rpx;
}

.summary-grid {
  margin-top: 20rpx;
}

.quick-row {
  margin-bottom: 12rpx;
}

.half-btn {
  flex: 1;
  margin-right: 10rpx;
}

.half-btn:last-child {
  margin-right: 0;
}

.job-card {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f3f8ff;
  border: 1rpx solid #d8e5f8;
}

.stat-row {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.stat-name {
  font-size: 28rpx;
  color: #0b2a4a;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.stat-val {
  color: #3f536f;
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.stat-total {
  margin-top: 14rpx;
  font-size: 27rpx;
  color: #0b2a4a;
  font-weight: 800;
}

.sub-title {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  color: #2f415a;
  font-size: 24rpx;
  font-weight: 700;
}

.pkg-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.pkg-name {
  color: #0b2a4a;
  font-size: 26rpx;
  font-weight: 600;
}

.pkg-qty {
  color: #334b68;
  font-size: 25rpx;
  font-weight: 700;
}
