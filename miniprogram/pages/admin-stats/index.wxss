/* =============================================
   统计页
   ============================================= */

/* 顶部按钮 */
.top-actions {
  width: 360rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.top-action-btn {
  margin: 0;
  min-width: 0;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 14rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-soft);
  border: 1rpx solid var(--color-primary-line);
  color: var(--color-primary-dark);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.top-action-btn::after {
  border: none;
}

.top-action-logout {
  background: var(--color-danger-soft);
  border-color: #fca5a5;
  color: #9a3412;
}

@media (max-width: 680rpx) {
  .top-actions {
    width: 100%;
    margin-top: 14rpx;
  }
}

/* 指标网格 */
.grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
  gap: 12rpx 0;
}

.grid-item {
  width: 33.33%;
  text-align: center;
  padding: 4rpx;
  box-sizing: border-box;
}

.metric-value {
  color: var(--color-primary-dark);
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 4rpx;
  letter-spacing: 0.5rpx;
}

.summary-grid {
  margin-top: 16rpx;
}

/* 日期/筛选 */
.picker-row {
  margin-bottom: 14rpx;
}

.quick-row {
  margin-bottom: 14rpx;
  gap: 10rpx;
}

.half-btn {
  flex: 1;
  margin: 0;
}

/* 任务卡片 */
.job-card {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: var(--radius-lg);
  background: var(--color-surface-alt);
  border: 1rpx solid var(--color-border);
}

/* 统计列表 */
.stat-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.stat-row:last-child {
  border-bottom: none;
}

.stat-name {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 700;
  margin-bottom: 6rpx;
}

.stat-val {
  color: var(--color-text-secondary);
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.stat-total {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: var(--color-primary-dark);
  font-weight: 800;
}

.sub-title {
  margin-top: 18rpx;
  margin-bottom: 8rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  font-weight: 700;
}

.pkg-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.pkg-row:last-child {
  border-bottom: none;
}

.pkg-name {
  color: var(--color-text);
  font-size: 26rpx;
  font-weight: 600;
}

.pkg-qty {
  color: var(--color-primary-dark);
  font-size: 26rpx;
  font-weight: 700;
}
