<view class="container">
  <view wx:if="{{!allowed}}" class="card">
    <view class="section-title">无权限</view>
    <view class="muted">仅食堂人员、管理员、超级管理员可访问菜品管理。</view>
  </view>

  <block wx:else>
    <view class="card hero-card">
      <view class="space-between hero-head">
        <view>
          <view class="section-title">菜品管理</view>
          <view class="muted helper-text">菜品按早/中/晚三套模板维护，每天的订餐自动复用；上传图片自动压缩（建议 4:3 横图）</view>
        </view>
        <button class="subtle-btn ghost-btn" size="mini" bindtap="logout">退出登录</button>
      </view>
      <view class="today-slots">
        <view class="today-slots-title">
          <text class="muted">订餐开关</text>
          <text class="muted today-slots-date">{{slotDayTabs[slotDayIndex].date}}</text>
        </view>
        <view class="slot-day-tabs">
          <view
            wx:for="{{slotDayTabs}}"
            wx:key="label"
            wx:for-index="dayIdx"
            class="slot-day-tab {{slotDayIndex === dayIdx ? 'slot-day-tab-active' : ''}}"
            data-index="{{dayIdx}}"
            bindtap="onSlotDayTabChange"
          >
            {{item.label}}
          </view>
        </view>
        <view class="today-slots-grid">
          <view wx:for="{{slotChips}}" wx:key="mealType" class="today-slot-chip {{item.isOpen ? 'today-slot-on' : 'today-slot-off'}}">
            <view class="today-slot-info">
              <text class="today-slot-label">{{item.label}}</text>
              <text class="today-slot-status">{{item.isOpen ? '开放中' : '已停止'}}</text>
            </view>
            <switch class="today-slot-switch" checked="{{item.isOpen}}" data-meal-type="{{item.mealType}}" bindchange="onToggleSlot" />
          </view>
        </view>
      </view>
      <view class="meal-tabs">
        <view
          wx:for="{{mealTypes}}"
          wx:key="value"
          wx:for-index="tabIndex"
          class="meal-tab {{activeIndex === tabIndex ? 'meal-tab-active' : ''}}"
          data-index="{{tabIndex}}"
          bindtap="onTabChange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="card">
      <view class="empty-text">加载中...</view>
    </view>

    <view class="card slot-shell">
      <view class="pkg-list">
        <block wx:for="{{packagesByType[mealTypes[activeIndex].value]}}" wx:key="id" wx:for-item="pkg" wx:for-index="pkgIndex">
          <view class="pkg-edit-card">
            <view class="pkg-top">
              <image class="meal-image" src="{{pkg.imagePreviewUrl}}" mode="aspectFill" lazy-load="true" />
              <view class="pkg-fields">
                <input
                  class="input compact-input"
                  placeholder="菜品名称"
                  value="{{pkg.packageName}}"
                  data-pkg-index="{{pkgIndex}}"
                  data-field="packageName"
                  bindinput="onPackageInput"
                />
                <view class="inline field-row">
                  <input
                    class="input compact-input price-input"
                    placeholder="单价"
                    type="digit"
                    value="{{pkg.priceInput}}"
                    data-pkg-index="{{pkgIndex}}"
                    data-field="priceInput"
                    bindinput="onPackageInput"
                  />
                  <picker
                    wx:if="{{mealTypes[activeIndex].value !== 'breakfast'}}"
                    mode="selector"
                    range="{{categoryLabels}}"
                    value="{{pkg.categoryIndex}}"
                    data-pkg-index="{{pkgIndex}}"
                    bindchange="onPackageCategoryChange"
                  >
                    <view class="tag-picker">{{categoryLabels[pkg.categoryIndex]}}</view>
                  </picker>
                </view>
              </view>
            </view>
            <view class="pkg-actions">
              <view class="toggle-line">
                <view class="muted">可选</view>
                <switch
                  checked="{{pkg.selectable}}"
                  data-pkg-index="{{pkgIndex}}"
                  bindchange="onPackageSelectableChange"
                />
              </view>
              <view class="action-row">
                <button
                  class="subtle-btn action-btn"
                  size="mini"
                  data-pkg-index="{{pkgIndex}}"
                  bindtap="choosePackageImage"
                >
                  更换图片
                </button>
                <button
                  class="warn-btn action-btn"
                  size="mini"
                  data-pkg-index="{{pkgIndex}}"
                  bindtap="deletePackage"
                >
                  删除菜品
                </button>
                <button class="primary-btn action-btn" size="mini" data-pkg-index="{{pkgIndex}}" bindtap="savePackage">
                  保存菜品
                </button>
              </view>
            </view>
          </view>
        </block>
        <view wx:if="{{!packagesByType[mealTypes[activeIndex].value].length}}" class="empty-text">尚未录入菜品，请在下方新增</view>
      </view>

      <view class="add-card">
        <view class="muted add-title">新增菜品</view>
        <view class="pkg-top">
          <image class="meal-image" src="{{drafts[mealTypes[activeIndex].value].imagePreviewUrl}}" mode="aspectFill" lazy-load="true" />
          <view class="pkg-fields">
            <input
              class="input compact-input"
              placeholder="菜品名称（如：包子）"
              value="{{drafts[mealTypes[activeIndex].value].packageName}}"
              data-field="packageName"
              bindinput="onDraftInput"
            />
            <view class="inline field-row">
              <input
                class="input compact-input price-input"
                placeholder="单价"
                type="digit"
                value="{{drafts[mealTypes[activeIndex].value].priceInput}}"
                data-field="priceInput"
                bindinput="onDraftInput"
              />
              <picker
                wx:if="{{mealTypes[activeIndex].value !== 'breakfast'}}"
                mode="selector"
                range="{{categoryLabels}}"
                value="{{drafts[mealTypes[activeIndex].value].categoryIndex}}"
                bindchange="onDraftCategoryChange"
              >
                <view class="tag-picker">{{categoryLabels[drafts[mealTypes[activeIndex].value].categoryIndex]}}</view>
              </picker>
            </view>
          </view>
        </view>
        <view class="muted new-tip">保存后将立即出现在所有日期的订餐页</view>
        <view class="pkg-actions">
          <view class="action-row two-cols">
            <button class="subtle-btn action-btn" size="mini" bindtap="chooseDraftImage">上传图片</button>
            <button class="primary-btn action-btn" size="mini" bindtap="addPackage">新增菜品</button>
          </view>
          <view class="action-row">
            <button class="subtle-btn action-btn full-btn" size="mini" bindtap="bulkImport">批量导入菜品</button>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
