.hero-card {
  background:
    radial-gradient(circle at 92% 12%, rgba(255, 214, 165, 0.24) 0, rgba(255, 214, 165, 0) 48%),
    linear-gradient(140deg, rgba(255, 255, 255, 0.96) 0%, rgba(238, 246, 255, 0.92) 100%);
}

.hero-head {
  align-items: flex-start;
  gap: 12rpx;
}

.hero-head > view:first-child {
  flex: 1;
  min-width: 0;
}

.helper-text {
  margin-top: 4rpx;
}

.ghost-btn {
  margin: 0;
  flex: 0 0 auto;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  border-radius: 14rpx;
  white-space: nowrap;
}

.picker-row {
  margin-top: 14rpx;
}

.picker-value {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  color: #0b2a4a;
  font-weight: 700;
  border: 1rpx solid #d3def0;
}

.meal-tabs {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.today-slots {
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid #d6e4f7;
}

.today-slots-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.today-slots-date {
  font-size: 22rpx;
}

.today-slots-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.slot-day-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.slot-day-tab {
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 12rpx;
  border: 1rpx solid #d3def0;
  background: #f4f7fc;
  color: #475569;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.slot-day-tab-active {
  background: linear-gradient(135deg, #0b2a4a 0%, #1e5fb6 100%);
  border-color: #0b2a4a;
  color: #ffffff;
}

.today-slot-chip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d3def0;
  background: #f4f7fc;
}

.today-slot-on {
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
  border-color: #86efac;
}

.today-slot-off {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  border-color: #fca5a5;
}

.today-slot-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.today-slot-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #0b2a4a;
}

.today-slot-status {
  font-size: 20rpx;
  color: #475569;
}

.today-slot-switch {
  transform: scale(0.7);
  transform-origin: right center;
  flex: 0 0 auto;
}

.meal-tab {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 14rpx;
  border: 1rpx solid #d3def0;
  background: #f4f7fc;
  color: #475569;
  font-size: 26rpx;
  font-weight: 600;
}

.meal-tab-active {
  background: linear-gradient(135deg, #0b2a4a 0%, #1e5fb6 100%);
  border-color: #0b2a4a;
  color: #ffffff;
}

.slot-shell {
  padding-top: 20rpx;
}

.slot-head {
  margin-bottom: 14rpx;
}

.slot-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #0b2a4a;
  font-size: 24rpx;
  font-weight: 700;
}

.slot-deadline {
  margin-top: 8rpx;
}

.switch-wrap {
  text-align: right;
}

.switch-pill {
  margin-top: 8rpx;
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.switch-on {
  background: #dcfce7;
  color: #166534;
}

.switch-off {
  background: #ffedd5;
  color: #9a3412;
}

.pkg-list {
  display: grid;
  gap: 14rpx;
}

.pkg-edit-card {
  padding: 14rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #f7fbff 0%, #edf4fd 100%);
  border: 1rpx solid #d6e4f7;
}

.pkg-top {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.meal-image {
  width: 168rpx;
  height: 126rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d5e3f6;
  background: #f0f5fb;
  flex-shrink: 0;
}

.pkg-fields {
  flex: 1;
}

.compact-input {
  height: 70rpx;
  margin-bottom: 10rpx;
  border-radius: 12rpx;
}

.field-row {
  gap: 10rpx;
}

.price-input {
  width: 42%;
  margin-bottom: 0;
}

.tag-picker {
  height: 70rpx;
  line-height: 70rpx;
  background: #e7effb;
  border-radius: 12rpx;
  padding: 0 18rpx;
  color: #0b2a4a;
  font-size: 24rpx;
  font-weight: 600;
}

.pkg-actions {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.toggle-line {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.action-row.two-cols {
  grid-template-columns: repeat(2, 1fr);
}

.action-btn {
  margin: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
  min-width: 0;
}

.action-btn.full-btn {
  grid-column: 1 / -1;
}

.action-btn::after {
  border: none;
}

.add-card {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 1rpx dashed #a7bddc;
  background: linear-gradient(145deg, #fbfdff 0%, #f1f7ff 100%);
}

.add-title {
  margin-bottom: 10rpx;
}

.new-tip {
  font-size: 22rpx;
  margin: 10rpx 0 4rpx;
}

.meal-type-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.meal-type-label {
  font-size: 24rpx;
}

.meal-type-check {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.meal-type-check checkbox {
  transform: scale(0.7);
}
