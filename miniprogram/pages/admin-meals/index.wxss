/* =============================================
   菜品管理页
   ============================================= */
.hero-card {
  background: linear-gradient(135deg, #0f5f9f 0%, #0b2a4a 100%);
  border: none;
  color: #ffffff;
}

.hero-card .section-title,
.hero-card .muted {
  color: #ffffff;
}

.hero-card .muted {
  opacity: 0.85;
}

.hero-head {
  align-items: flex-start;
  gap: 12rpx;
}

.hero-head > view:first-child {
  flex: 1;
  min-width: 0;
}

.helper-text {
  margin-top: 4rpx;
  font-size: 24rpx;
}

.ghost-btn {
  margin: 0;
  flex: 0 0 auto;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  border: none;
  white-space: nowrap;
}

.ghost-btn::after {
  border: none;
}

/* 订餐开关板块 */
.today-slots {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(8rpx);
}

.today-slots-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.today-slots-title .muted {
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
  font-size: 26rpx;
}

.today-slots-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.slot-day-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  padding: 6rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 999rpx;
  margin-bottom: 12rpx;
}

.slot-day-tab {
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  font-weight: 600;
}

.slot-day-tab-active {
  background: #ffffff;
  color: #0b2a4a;
}

.today-slots-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.today-slot-chip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6rpx;
  padding: 10rpx 14rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.92);
}

.today-slot-on {
  background: #dbeafe;
}

.today-slot-off {
  background: #fee2e2;
}

.today-slot-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.today-slot-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
}

.today-slot-status {
  font-size: 20rpx;
  color: #6b7280;
}

.today-slot-switch {
  transform: scale(0.7);
  transform-origin: right center;
  flex: 0 0 auto;
}

/* 餐别 tab（早餐/午晚餐） */
.meal-tabs {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8rpx;
  padding: 6rpx;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 999rpx;
}

.meal-tab {
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 26rpx;
  font-weight: 600;
}

.meal-tab-active {
  background: #ffffff;
  color: #0b2a4a;
}

/* 菜品列表 */
.slot-shell {
  padding-top: 20rpx;
}

.pkg-list {
  display: grid;
  gap: 14rpx;
}

.pkg-edit-card {
  padding: 16rpx;
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
}

.pkg-top {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.meal-image {
  width: 168rpx;
  height: 132rpx;
  border-radius: var(--radius-md);
  background: var(--color-divider);
  flex-shrink: 0;
}

.pkg-fields {
  flex: 1;
  min-width: 0;
}

.compact-input {
  height: 70rpx;
  margin-bottom: 10rpx;
  border-radius: var(--radius-md);
  font-size: 26rpx;
}

.field-row {
  gap: 10rpx;
}

.price-input {
  width: 28%;
  margin-bottom: 0;
}

.unit-input {
  width: 22%;
  margin-bottom: 0;
}

.tag-picker {
  height: 70rpx;
  line-height: 70rpx;
  background: var(--color-primary-soft);
  border-radius: var(--radius-md);
  padding: 0 18rpx;
  color: var(--color-primary-dark);
  font-size: 24rpx;
  font-weight: 600;
}

.meal-type-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: var(--color-primary-dark);
  background-color: var(--color-primary-soft);
  border-radius: 999rpx;
  align-self: flex-start;
  font-weight: 600;
}

.meal-type-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.meal-type-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.meal-type-check {
  display: flex;
  align-items: center;
  gap: 2rpx;
  font-size: 24rpx;
}

.meal-type-check checkbox {
  transform: scale(0.7);
}

.pkg-actions {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.toggle-line {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.action-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}

.action-row.two-cols {
  grid-template-columns: repeat(2, 1fr);
}

.action-btn {
  margin: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 8rpx;
  border-radius: var(--radius-md);
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.action-btn.full-btn {
  grid-column: 1 / -1;
}

.action-btn::after {
  border: none;
}

/* 新增菜品卡片 */
.add-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: var(--radius-lg);
  border: 2rpx dashed var(--color-primary-line);
  background: var(--color-surface-alt);
}

.add-title {
  margin-bottom: 12rpx;
  color: var(--color-primary-dark);
  font-weight: 700;
  font-size: 26rpx;
}

.new-tip {
  font-size: 22rpx;
  margin: 10rpx 0 4rpx;
  color: var(--color-text-muted);
}
