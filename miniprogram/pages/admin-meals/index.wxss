.hero-card {
  background:
    radial-gradient(circle at 92% 12%, rgba(255, 214, 165, 0.24) 0, rgba(255, 214, 165, 0) 48%),
    linear-gradient(140deg, rgba(255, 255, 255, 0.96) 0%, rgba(238, 246, 255, 0.92) 100%);
}

.hero-head {
  align-items: flex-start;
}

.helper-text {
  margin-top: 4rpx;
}

.ghost-btn {
  margin-left: 12rpx;
}

.picker-row {
  margin-top: 14rpx;
}

.picker-value {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  color: #0b2a4a;
  font-weight: 700;
  border: 1rpx solid #d3def0;
}

.create-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.create-chip {
  border-radius: 999rpx;
  background: linear-gradient(135deg, #edf5ff 0%, #dbe9fd 100%);
  color: #0b2a4a;
  font-size: 24rpx;
  border: 1rpx solid #cedff7;
}

.slot-shell {
  padding-top: 20rpx;
}

.slot-head {
  margin-bottom: 14rpx;
}

.slot-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #0b2a4a;
  font-size: 24rpx;
  font-weight: 700;
}

.slot-deadline {
  margin-top: 8rpx;
}

.switch-wrap {
  text-align: right;
}

.switch-pill {
  margin-top: 8rpx;
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.switch-on {
  background: #dcfce7;
  color: #166534;
}

.switch-off {
  background: #ffedd5;
  color: #9a3412;
}

.pkg-list {
  display: grid;
  gap: 14rpx;
}

.pkg-edit-card {
  padding: 14rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #f7fbff 0%, #edf4fd 100%);
  border: 1rpx solid #d6e4f7;
}

.pkg-top {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.meal-image {
  width: 168rpx;
  height: 126rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d5e3f6;
  background: #f0f5fb;
  flex-shrink: 0;
}

.pkg-fields {
  flex: 1;
}

.compact-input {
  height: 70rpx;
  margin-bottom: 10rpx;
  border-radius: 12rpx;
}

.field-row {
  gap: 10rpx;
}

.price-input {
  width: 42%;
  margin-bottom: 0;
}

.tag-picker {
  height: 70rpx;
  line-height: 70rpx;
  background: #e7effb;
  border-radius: 12rpx;
  padding: 0 18rpx;
  color: #0b2a4a;
  font-size: 24rpx;
  font-weight: 600;
}

.pkg-actions {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.toggle-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.action-btn {
  margin: 0;
}

.delete-btn {
  white-space: nowrap;
}

.add-card {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 1rpx dashed #a7bddc;
  background: linear-gradient(145deg, #fbfdff 0%, #f1f7ff 100%);
}

.add-title {
  margin-bottom: 10rpx;
}

.new-tip {
  font-size: 22rpx;
}
