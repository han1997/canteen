<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-bar-item {{index === selected ? 'tab-bar-item-active' : ''}}"
    style="color: {{index === selected ? selectedColor : color}}"
    data-path="{{item.pagePath}}"
    bindtap="onTap"
  >
    <view class="tab-bar-text">{{item.text}}</view>
  </view>
</view>
